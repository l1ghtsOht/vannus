*.db-shm

# Backups (manual, accidental, or tool-generated)
*.bak
*.backup

# Generic logs (defensive — not currently produced, but cheap insurance)
*.log

# direnv (developer convenience, not a project file)
.envrc

# Runtime data files accidentally created at repo root
# (real seed data lives in praxis/feedback.json and praxis/usage.json)
/feedback.json
/usage.json

